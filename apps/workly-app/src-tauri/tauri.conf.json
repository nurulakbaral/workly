{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "@workly/app",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run:local:app",
    "beforeBuildCommand": "pnpm build:prod:app"
  },
  "app": {
    "windows": [
      {
        "title": "@workly/app",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
